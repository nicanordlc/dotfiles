#!/bin/bash
set -Eeuo pipefail

# 1. Check if Spotify is running without using grep
if ! pgrep -x "Spotify" >/dev/null; then
    echo "🎹"
    exit 0 # Exit gracefully if not running
fi

# 2. Fetch all metadata in a single AppleScript call
# We use a custom delimiter ( | ) to split the data easily in bash
IFS='|' read -r state artist track <<EOF
$(osascript -e 'tell application "Spotify"
    set track_name to name of current track
    set artist_name to artist of current track
    set player_state to player state as string
    return player_state & "|" & artist_name & "|" & track_name
end tell' 2>/dev/null)
EOF

# 3. Assign icons based on state
[[ "$state" == "playing" ]] && icon="▶️ " || icon="⏸️ "

# 4. Output results
echo "${icon}${artist} [${track}]"
